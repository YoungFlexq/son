{
  "manifest_version": 3,
  "name": "Vault — Roblox Limiteds Tracker",
  "version": "1.0.0",
  "description": "Track RAP, value, demand & risk for every Roblox limited. Auto-buy at your target price instantly.",
  "action": {
    "default_title": "Vault",
    "default_popup": "popup/index.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "permissions": [
    "storage",
    "alarms",
    "cookies",
    "notifications"
  ],
  "host_permissions": [
    "https://*.roblox.com/*",
    "https://*.rolimons.com/*"
  ],
  "minimum_chrome_version": "102"
}
